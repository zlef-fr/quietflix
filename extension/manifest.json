{
  "manifest_version": 3,
  "name": "QuietFlix — Tame Netflix Preview Volume",
  "version": "1.0.0",
  "description": "Netflix autoplay previews blast at full volume. QuietFlix silently mirrors your real player volume to every preview. No more 2 a.m. trailer jump-scares.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "QuietFlix",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["*://*.netflix.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.netflix.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
